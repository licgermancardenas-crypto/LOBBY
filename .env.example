NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

# URL pública del sitio (opcional; en Vercel se deriva de VERCEL_PROJECT_PRODUCTION_URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Twitch OAuth — verificación de audiencia. Crear app en https://dev.twitch.tv/console/apps
# Redirect OAuth de la app: <site-url>/api/twitch/callback
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# Secreto del cron de refresh (Vercel Cron manda Authorization: Bearer <valor>)
CRON_SECRET=un-string-largo-y-aleatorio
